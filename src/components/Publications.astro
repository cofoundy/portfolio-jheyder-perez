---
import { siteConfig } from "../config";
---

<section id="publicaciones" class="py-16 md:py-20" style={`background-color: ${siteConfig.accentColor}08`}>
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <h2 class="reveal text-2xl md:text-3xl font-bold text-center mb-4" style={`color: ${siteConfig.accentColor}`}>
      Publicaciones
    </h2>
    <div class="reveal w-16 h-1 mx-auto mb-12 rounded-full" style={`background-color: ${siteConfig.highlightColor}`}></div>

    <div class="space-y-6">
      {siteConfig.publications?.map((pub, i) => {
        const Wrapper = pub.link ? "a" : "div";
        const linkProps = pub.link ? { href: pub.link, target: "_blank", rel: "noopener noreferrer" } : {};
        return (
          <Wrapper
            {...linkProps}
            class={`reveal group bg-white p-6 rounded-xl border transition-all duration-300 hover:shadow-md ${pub.link ? "block cursor-pointer hover:-translate-y-0.5" : ""}`}
            style={`border-color: ${siteConfig.accentColor}15`}
          >
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 mt-1">
                <span
                  class="inline-flex items-center justify-center w-8 h-8 rounded-full text-white text-sm font-bold"
                  style={`background-color: ${siteConfig.accentColor}`}
                >
                  {i + 1}
                </span>
              </div>
              <div class="flex-1">
                <div class="flex flex-wrap items-center gap-2 mb-2">
                  <span
                    class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium text-white"
                    style={`background-color: ${pub.type === "journal" ? siteConfig.highlightColor : siteConfig.accentColor}`}
                  >
                    {pub.type === "journal" ? "Journal" : "Conferencia"}
                  </span>
                  <span class="text-sm text-gray-500">({pub.year})</span>
                  {pub.note && (
                    <span class="text-xs text-gray-400 italic">{pub.note}</span>
                  )}
                </div>
                <h3 class="text-base font-semibold text-gray-900 mb-1 leading-snug transition-colors" style={pub.link ? `--hover-color: ${siteConfig.highlightColor}` : ""}>
                  {pub.title}
                </h3>
                <p class="text-sm text-gray-500">{pub.authors}</p>
                <p class="text-sm font-medium mt-1" style={`color: ${siteConfig.accentColor}`}>
                  {pub.venue}
                </p>
                {pub.link && (
                  <div class="mt-3 inline-flex items-center gap-1 text-xs font-medium transition-all duration-300 group-hover:gap-2" style={`color: ${siteConfig.highlightColor}`}>
                    Ver artículo completo
                    <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                    </svg>
                  </div>
                )}
              </div>
            </div>
          </Wrapper>
        );
      })}
    </div>

    {siteConfig.social?.scholar && (
      <div class="reveal text-center mt-8">
        <a
          href={siteConfig.social.scholar}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-white font-medium transition-transform duration-200 hover:scale-105"
          style={`background-color: ${siteConfig.accentColor}`}
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/>
          </svg>
          Ver todas en Google Scholar
        </a>
      </div>
    )}
  </div>
</section>
