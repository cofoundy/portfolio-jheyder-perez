---
import { siteConfig } from "../config";
const hasScholarships = siteConfig.scholarships && siteConfig.scholarships.length > 0;
const hasAwards = siteConfig.awards && siteConfig.awards.length > 0;
const hasResearchLines = siteConfig.researchLines && siteConfig.researchLines.length > 0;
const hasAny = hasScholarships || hasAwards || hasResearchLines;
---

{hasAny && (
  <section id="achievements" class="py-12 md:py-16 bg-white">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="mb-10 reveal-left">
        <h2 class="text-3xl md:text-4xl font-bold" style={`color: ${siteConfig.accentColor}`}>
          Becas, Premios y Líneas de Investigación
        </h2>
        <div class="w-16 h-1 mt-3 rounded-full" style={`background-color: ${siteConfig.highlightColor}`}></div>
      </div>

      <div class="space-y-12">
        {hasScholarships && (
          <div class="reveal">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center" style={`background-color: ${siteConfig.highlightColor}15`}>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style={`color: ${siteConfig.highlightColor}`}>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"></path>
                </svg>
              </div>
              <h3 class="text-xl md:text-2xl font-semibold" style={`color: ${siteConfig.accentColor}`}>Becas</h3>
            </div>
            <div class="grid grid-cols-1 gap-4">
              {siteConfig.scholarships.map((s) => (
                <div class="p-5 rounded-xl bg-gray-50 card-hover" style={`border: 1px solid ${siteConfig.accentColor}12`}>
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-2">
                    <h4 class="text-base md:text-lg font-semibold" style={`color: ${siteConfig.accentColor}`}>{s.name}</h4>
                    <span class="text-xs px-3 py-1 rounded-full self-start whitespace-nowrap" style={`background-color: ${siteConfig.highlightColor}15; color: ${siteConfig.highlightColor}`}>
                      {s.year}
                    </span>
                  </div>
                  <p class="text-sm font-medium mb-2" style={`color: ${siteConfig.highlightColor}`}>{s.issuer}</p>
                  <p class="text-sm text-gray-600 leading-relaxed">{s.description}</p>
                </div>
              ))}
            </div>
          </div>
        )}

        {hasAwards && (
          <div class="reveal">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center" style={`background-color: ${siteConfig.highlightColor}15`}>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style={`color: ${siteConfig.highlightColor}`}>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
                </svg>
              </div>
              <h3 class="text-xl md:text-2xl font-semibold" style={`color: ${siteConfig.accentColor}`}>Premios</h3>
            </div>
            <div class="grid grid-cols-1 gap-4">
              {siteConfig.awards.map((a) => (
                <div class="p-5 rounded-xl bg-gray-50 card-hover" style={`border: 1px solid ${siteConfig.accentColor}12`}>
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-2">
                    <h4 class="text-base md:text-lg font-semibold" style={`color: ${siteConfig.accentColor}`}>{a.name}</h4>
                    <span class="text-xs px-3 py-1 rounded-full self-start whitespace-nowrap" style={`background-color: ${siteConfig.highlightColor}15; color: ${siteConfig.highlightColor}`}>
                      {a.year}
                    </span>
                  </div>
                  <p class="text-sm font-medium mb-2" style={`color: ${siteConfig.highlightColor}`}>{a.issuer}</p>
                  <p class="text-sm text-gray-600 leading-relaxed">{a.description}</p>
                </div>
              ))}
            </div>
          </div>
        )}

        {hasResearchLines && (
          <div class="reveal">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center" style={`background-color: ${siteConfig.highlightColor}15`}>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style={`color: ${siteConfig.highlightColor}`}>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
                </svg>
              </div>
              <h3 class="text-xl md:text-2xl font-semibold" style={`color: ${siteConfig.accentColor}`}>Líneas de Investigación</h3>
            </div>
            <div class="grid grid-cols-1 gap-4">
              {siteConfig.researchLines.map((r, idx) => (
                <div class="p-5 rounded-xl bg-gray-50 card-hover flex gap-4" style={`border: 1px solid ${siteConfig.accentColor}12`}>
                  <div
                    class="w-10 h-10 rounded-lg flex items-center justify-center text-sm font-bold flex-shrink-0"
                    style={`background-color: ${siteConfig.highlightColor}20; color: ${siteConfig.highlightColor}`}
                  >
                    0{idx + 1}
                  </div>
                  <div class="flex-1">
                    <h4 class="text-base md:text-lg font-semibold mb-1" style={`color: ${siteConfig.accentColor}`}>{r.title}</h4>
                    <p class="text-sm text-gray-600 leading-relaxed">{r.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </section>
)}
