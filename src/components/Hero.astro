---
import { siteConfig } from "../config";
---

<!-- Accent Shimmer Bar -->
<div
  class="w-full h-2 accent-bar-shimmer"
  style={`background: linear-gradient(90deg, ${siteConfig.accentColor} 0%, ${siteConfig.highlightColor} 50%, ${siteConfig.accentColor} 100%)`}
></div>

<section
  id="hero"
  class="relative py-12 md:py-16 lg:py-20 bg-gray-50"
>
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <!-- Main Hero Content -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 items-center">
      <!-- Photo -->
      <div class="order-2 md:order-1 flex justify-center md:justify-start">
        <div class="relative hero-photo">
          <div
            class="absolute -inset-3 rounded-2xl opacity-20"
            style={`background-color: ${siteConfig.accentColor}`}
          ></div>
          <img
            src="/profile.png"
            alt={siteConfig.name}
            class="relative w-56 md:w-72 lg:w-80 h-auto object-contain rounded-2xl shadow-xl bg-gray-100"
            style={`border: 4px solid ${siteConfig.highlightColor}; aspect-ratio: 3/4;`}
          />
        </div>
      </div>

      <!-- Text Content -->
      <div class="order-1 md:order-2 text-center md:text-left">
        <h1
          class="hero-title text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight"
          style={`color: ${siteConfig.accentColor}`}
        >
          {siteConfig.name}
        </h1>
        <p
          class="hero-subtitle text-xl md:text-2xl font-light mt-2 mb-3"
          style={`color: ${siteConfig.highlightColor}`}
        >
          {siteConfig.title}
        </p>
        <div
          class="w-16 h-1 mb-4 mx-auto md:mx-0 rounded-full"
          style={`background-color: ${siteConfig.highlightColor}`}
        ></div>
        <p class="hero-description text-base md:text-lg text-gray-600 leading-relaxed mb-6 max-w-md mx-auto md:mx-0">
          {siteConfig.tagline}
        </p>

        <!-- CTA Button -->
        {siteConfig.social?.email && (
          <a
            href={`mailto:${siteConfig.social.email}`}
            class="hero-cta inline-flex items-center gap-2 px-6 py-3 rounded-full text-white font-medium transition-transform duration-200 hover:scale-105 mb-6"
            style={`background-color: ${siteConfig.highlightColor}`}
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            Contáctame
          </a>
        )}

        <!-- Social Links -->
        <div class="hero-social flex gap-3 justify-center md:justify-start">
          {siteConfig.social?.email && (
            <a href={`mailto:${siteConfig.social.email}`} class="icon-hover w-10 h-10 rounded-full flex items-center justify-center" style={`background-color: ${siteConfig.accentColor}; color: white`} aria-label="Email">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </a>
          )}
          {siteConfig.social?.linkedin && (
            <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" class="icon-hover w-10 h-10 rounded-full flex items-center justify-center" style={`background-color: ${siteConfig.accentColor}; color: white`} aria-label="LinkedIn">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          )}
          {siteConfig.social?.researchgate && (
            <a href={siteConfig.social.researchgate} target="_blank" rel="noopener noreferrer" class="icon-hover w-10 h-10 rounded-full flex items-center justify-center" style={`background-color: ${siteConfig.accentColor}; color: white`} aria-label="ResearchGate">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.586 0c-1.37.007-2.476 1.116-2.476 2.487s1.106 2.487 2.476 2.487c1.37 0 2.476-1.116 2.476-2.487S20.956 0 19.586 0zm-7.22 2.715c-3.357 0-5.235 2.27-5.235 4.9 0 2.11 1.268 3.79 3.235 4.52-.12.34-.27.67-.41.97-.47 1.01-1.05 1.89-1.59 2.55-.56.69-1.07 1.14-1.32 1.32-.13.09-.23.15-.29.17-.03.01-.05.01-.05 0-.02-.03-.03-.1-.03-.21 0-.42.14-1.16.4-2.01.26-.85.57-1.78.85-2.63l.02-.05c.08-.24-.05-.5-.29-.58-.24-.08-.5.05-.58.29l-.02.05c-.29.87-.6 1.82-.87 2.7-.27.88-.44 1.7-.44 2.26 0 .3.04.55.15.74.11.19.31.31.56.31.34-.01.73-.21 1.16-.55.62-.5 1.3-1.25 1.95-2.12.52-.7 1.01-1.48 1.44-2.33.14-.27.27-.55.39-.83 1.33.26 2.86.11 4.17-.58 1.73-1.37 2.04-3.28 2.04-3.28v-.01c.77.07 1.46.57 1.46 1.37 0 .82-.67 1.41-1.51 1.83-.17.09-.23.3-.14.47.09.17.3.23.47.14 1.07-.54 1.96-1.42 1.96-2.44 0-1.37-1.22-2.14-2.53-2.14h-.02c-.13-1.07-.6-2.04-1.38-2.72-.84-.73-1.96-1.13-3.26-1.13zm.04 1.24c1.02 0 1.86.31 2.49.85.51.44.86 1.03.99 1.72-.41-.05-.84-.05-1.29.02-1.71.27-3.07 1.37-3.48 2.75-.7-.57-1.11-1.41-1.11-2.49 0-1.69 1.13-2.85 2.4-2.85z"/></svg>
            </a>
          )}
          {siteConfig.social?.scholar && (
            <a href={siteConfig.social.scholar} target="_blank" rel="noopener noreferrer" class="icon-hover w-10 h-10 rounded-full flex items-center justify-center" style={`background-color: ${siteConfig.accentColor}; color: white`} aria-label="Google Scholar">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/></svg>
            </a>
          )}
          {siteConfig.social?.whatsapp && (
            <a href={siteConfig.social.whatsapp} target="_blank" rel="noopener noreferrer" class="icon-hover w-10 h-10 rounded-full flex items-center justify-center" style={`background-color: ${siteConfig.accentColor}; color: white`} aria-label="WhatsApp">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </a>
          )}
        </div>
      </div>
    </div>

    <!-- Stats Row -->
    {siteConfig.stats && siteConfig.stats.length > 0 && (
      <div class="hero-stats grid grid-cols-3 gap-4 md:gap-8 mt-12 pt-8 border-t" style={`border-color: ${siteConfig.accentColor}20`}>
        {siteConfig.stats.map((stat) => (
          <div class="text-center stat-number">
            <div class="text-2xl md:text-3xl lg:text-4xl font-bold" style={`color: ${siteConfig.highlightColor}`}>
              {stat.value}
            </div>
            <div class="text-xs md:text-sm text-gray-600 mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<!-- Bottom Accent Bar -->
<div
  class="w-full h-2 accent-bar-shimmer"
  style={`background: linear-gradient(90deg, ${siteConfig.accentColor} 0%, ${siteConfig.highlightColor} 50%, ${siteConfig.accentColor} 100%)`}
></div>
